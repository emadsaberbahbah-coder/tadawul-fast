def test_compute_scores_returns_dict(scoring):
    result = scoring.compute_scores(MINIMAL_ROW)
    assert isinstance(result, dict), f"Expected dict, got {type(result)}"


def test_compute_scores_required_keys_present(scoring):
    result = scoring.compute_scores(RICH_ROW)
    missing = REQUIRED_OUTPUT_KEYS - set(result.keys())
    assert not missing, f"compute_scores missing required keys: {sorted(missing)}"


def test_compute_scores_score_fields_are_float_or_none(scoring):
    result = scoring.compute_scores(RICH_ROW)
    for key in SCORE_FLOAT_FIELDS:
        val = result.get(key)
        if val is not None:
            assert isinstance(val, (int, float)), f"Field '{key}' = {val!r} is not numeric"
            assert not math.isnan(float(val)),   f"Field '{key}' is NaN"
            assert not math.isinf(float(val)),   f"Field '{key}' is Inf"


def test_compute_scores_scores_in_0_100(scoring):
    """Score fields (except forecast_confidence/penalty_factor) should be in [0, 100]."""
    result = scoring.compute_scores(RICH_ROW)
    skip = {"forecast_confidence", "overall_penalty_factor"}
    for key in SCORE_FLOAT_FIELDS - skip:
        val = result.get(key)
        if val is not None:
            assert 0.0 <= float(val) <= 100.0, (
                f"Score field '{key}' = {val} is outside [0, 100]"
            )


def test_compute_scores_forecast_confidence_is_fraction(scoring):
    """forecast_confidence is stored as a fraction 0.0–1.0."""
    result = scoring.compute_scores(RICH_ROW)
    fc = result.get("forecast_confidence")
    if fc is not None:
        assert 0.0 <= float(fc) <= 1.0, (
            f"forecast_confidence = {fc} is not a fraction [0, 1]. "
            "Schema stores fractions, not percent."
        )


def test_compute_scores_roi_fields_are_fractions(scoring):
    """Expected ROI fields must be fractions (not percent points)."""
    result = scoring.compute_scores(RICH_ROW)
    for key in ("expected_roi_1m", "expected_roi_3m", "expected_roi_12m"):
        val = result.get(key)
        if val is not None:
            assert abs(float(val)) <= 1.5, (
                f"'{key}' = {val} looks like percent points, expected fraction. "
                "Schema dtype=pct stores fractions (0.085 = 8.5%, not 8.5)."
            )


