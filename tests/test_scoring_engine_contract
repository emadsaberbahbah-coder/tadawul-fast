def test_scoring_module_is_importable():
    sm = _load_scoring()
    assert sm is not None


def test_scoring_version_present(scoring):
    v = getattr(scoring, "SCORING_VERSION", None) or getattr(scoring, "__version__", None)
    assert v is not None, "SCORING_VERSION / __version__ not found in scoring module"
    parts = str(v).split(".")
    assert len(parts) >= 2, f"Version '{v}' does not look like semver"
    for part in parts:
        digits = "".join(c for c in part if c.isdigit())
        assert digits, f"Version part '{part}' contains no digits"


def test_scoring_version_and_dunder_match(scoring):
    """v2.1.0: SCORING_VERSION and __version__ must match if both present."""
    sv = getattr(scoring, "SCORING_VERSION", None)
    dv = getattr(scoring, "__version__", None)
    if sv is not None and dv is not None:
        assert str(sv) == str(dv), (
            f"SCORING_VERSION ({sv}) != __version__ ({dv})"
        )


def test_scoring_all_exports(scoring):
    """
    v2.1.0: Checks every name in scoring.__all__ (not just a subset).
    v2.0.0 missed: assign_rank_overall, ForecastParameters, ScoringEngine,
    DEFAULT_FORECASTS, score_quote, ScoringWeights, __version__.
    """
    required = [
        # Core public API
        "compute_scores",
        "score_row",
        "score_quote",          # v2.1.0: added (third alias)
        "enrich_with_scores",
        # Ranking
        "rank_rows_by_overall",
        "assign_rank_overall",  # v2.1.0: added
        "score_and_rank_rows",
        # Dataclasses + wrapper
        "AssetScores",
        "ScoreWeights",
        "ScoringWeights",       # v2.1.0: added (compat alias)
        "ForecastParameters",   # v2.1.0: added
        "ScoringEngine",        # v2.1.0: added
        # Defaults
        "DEFAULT_WEIGHTS",
        "DEFAULT_FORECASTS",    # v2.1.0: added
        # Version
        "SCORING_VERSION",
        "__version__",          # v2.1.0: added
    ]
    missing = [name for name in required if not hasattr(scoring, name)]
    assert not missing, f"scoring module missing exports: {missing}"


