def test_score_weights_default_sum(scoring):
    """Primary score weights sum to 1.0 (allowing tolerance for float arithmetic)."""
    w = scoring.DEFAULT_WEIGHTS
    total = (
        getattr(w, "w_valuation", 0.0)
        + getattr(w, "w_momentum", 0.0)
        + getattr(w, "w_quality", 0.0)
        + getattr(w, "w_growth", 0.0)
        + getattr(w, "w_opportunity", 0.0)
    )
    assert abs(total - 1.0) < 1e-6, (
        f"ScoreWeights primary fields sum to {total}, expected 1.0"
    )


def test_score_weights_each_positive(scoring):
    w = scoring.DEFAULT_WEIGHTS
    for name in ("w_valuation", "w_momentum", "w_quality", "w_growth", "w_opportunity"):
        val = getattr(w, name, None)
        assert val is not None, f"ScoreWeights.{name} missing"
        assert val >= 0.0, f"ScoreWeights.{name} is negative: {val}"


def test_score_weights_penalty_bounds(scoring):
    w = scoring.DEFAULT_WEIGHTS
    for name in ("risk_penalty_strength", "confidence_penalty_strength"):
