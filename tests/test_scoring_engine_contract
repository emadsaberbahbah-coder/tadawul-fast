def _make_rows(n: int) -> List[Dict[str, Any]]:
    rows = []
    for i in range(n):
        base = dict(MINIMAL_ROW)
        base["symbol"] = f"TICK{i:03d}.SR"
        base["overall_score"] = float(i * 10)
        rows.append(base)
    return rows


def test_rank_rows_by_overall_assigns_rank_field(scoring):
    """
    v2.1.0 FIX: Renamed from `test_rank_rows_by_overall_ordering`.

    v2.0.0 incorrectly asserted that `rank_rows_by_overall` RETURNS rows
    sorted by score descending. But scoring.py v2.2.0's implementation
    preserves original order and only ASSIGNS `rank_overall` to each row:

        def rank_rows_by_overall(rows, *, key_overall="overall_score"):
            return assign_rank_overall(rows, ..., inplace=True,
                                        rank_key="rank_overall")
            # target is returned in ORIGINAL order; only rank_overall
            # is computed from sorted-desc position.

    Correct contract: rows stay in original order, but each row carries
    a `rank_overall` corresponding to its rank when sorted by
    overall_score descending.
    """
    rows = _make_rows(5)  # scores 0, 10, 20, 30, 40 (ascending by construction)
    ranked = scoring.rank_rows_by_overall(rows)

    # Order preserved (NOT reordered)
    scores = [float(r.get("overall_score") or 0) for r in ranked]
    assert scores == [0.0, 10.0, 20.0, 30.0, 40.0], (
        f"rank_rows_by_overall must preserve input order, got scores {scores}"
    )

    # But rank_overall reflects sorted-descending position
    # score=40 (index 4) → rank 1 (highest)
    # score=0  (index 0) → rank 5 (lowest)
    expected_ranks = [5, 4, 3, 2, 1]
    actual_ranks = [r.get("rank_overall") for r in ranked]
    assert actual_ranks == expected_ranks, (
        f"rank_overall must reflect sorted-desc position. "
        f"Expected {expected_ranks}, got {actual_ranks}"
    )


