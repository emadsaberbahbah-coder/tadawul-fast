# =============================================================================
# Scoring module loader — multi-path fallback
# =============================================================================
_SCORING_MODULE_CANDIDATES = (
    "core.scoring",
    "core.sheets.scoring",
    "scoring",
)


def _load_scoring() -> Any:
    last: Optional[Exception] = None
    for path in _SCORING_MODULE_CANDIDATES:
        try:
            return importlib.import_module(path)
        except Exception as e:
            last = e
    raise RuntimeError(
        f"Cannot import scoring module from any of {_SCORING_MODULE_CANDIDATES}. "
        f"Last error: {last!r}"
    )


@pytest.fixture(scope="module")
def scoring():
    return _load_scoring()


