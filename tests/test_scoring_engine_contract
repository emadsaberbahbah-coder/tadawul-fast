def _make_rows(n: int) -> List[Dict[str, Any]]:
    rows = []
    for i in range(n):
        base = dict(MINIMAL_ROW)
        base["symbol"]       = f"TICK{i:03d}.SR"
        base["overall_score"] = float(i * 10)
        rows.append(base)
    return rows


def test_rank_rows_by_overall_ordering(scoring):
    rows = _make_rows(5)
    ranked = scoring.rank_rows_by_overall(rows)
    scores = [float(r.get("overall_score") or 0) for r in ranked]
    assert scores == sorted(scores, reverse=True), "rank_rows_by_overall should be descending"


def test_assign_rank_overall_adds_rank(scoring):
    rows = _make_rows(3)
    ranked = scoring.assign_rank_overall(rows)
    for idx, row in enumerate(ranked, start=1):
        assert row.get("rank_overall") == idx, (
            f"row {idx}: rank_overall = {row.get('rank_overall')}, expected {idx}"
        )


def test_score_and_rank_rows_end_to_end(scoring):
    rows = [dict(RICH_ROW), dict(MINIMAL_ROW), dict(SPARSE_ROW)]
    results = scoring.score_and_rank_rows(rows)
    assert isinstance(results, list)
    assert len(results) == 3
    for row in results:
        assert "overall_score" in row
        assert "recommendation" in row
        assert row.get("recommendation") in VALID_RECOMMENDATIONS


def test_score_and_rank_rows_rank_is_contiguous(scoring):
    rows = [dict(RICH_ROW), dict(MINIMAL_ROW), dict(SPARSE_ROW)]
    results = scoring.score_and_rank_rows(rows)
    ranks = [r.get("rank_overall") for r in results if r.get("rank_overall") is not None]
    if ranks:
        assert sorted(ranks) == list(range(1, len(ranks) + 1)), (
            f"rank_overall values are not contiguous 1..N: {ranks}"
        )


def test_score_and_rank_rows_empty_input(scoring):
    results = scoring.score_and_rank_rows([])
    assert results == []


