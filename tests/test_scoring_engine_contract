def test_assign_rank_overall_adds_rank(scoring):
    """
    v2.1.0 FIX: v2.0.0 used `enumerate(ranked, start=1)` and asserted
    `rank_overall == idx`, which only holds if the list is already sorted
    desc by score. But `_make_rows(3)` produces ASCENDING scores (0, 10,
    20), and `assign_rank_overall` preserves order — so position-0 gets
    the LOWEST score and thus rank 3, not rank 1.

    Correct contract: rank_overall reflects the row's rank when sorted
    by overall_score descending, but the output list preserves input
    order.
    """
    rows = _make_rows(3)  # scores 0, 10, 20 (ascending)
    ranked = scoring.assign_rank_overall(rows)
    # assign_rank_overall preserves order; each row gets rank by sorted-desc position
    assert ranked[0].get("rank_overall") == 3, (
        f"row 0 (score=0, lowest) should have rank 3, "
        f"got {ranked[0].get('rank_overall')}"
    )
    assert ranked[1].get("rank_overall") == 2, (
        f"row 1 (score=10, middle) should have rank 2, "
        f"got {ranked[1].get('rank_overall')}"
    )
    assert ranked[2].get("rank_overall") == 1, (
        f"row 2 (score=20, highest) should have rank 1, "
        f"got {ranked[2].get('rank_overall')}"
    )


def test_assign_rank_overall_rank_contiguous(scoring):
    """
    v2.1.0: Regardless of input order, the set of assigned ranks must be
    {1, 2, ..., N} — no duplicates, no gaps.
    """
    rows = _make_rows(7)
    ranked = scoring.assign_rank_overall(rows)
    ranks = sorted(r.get("rank_overall") for r in ranked)
    assert ranks == list(range(1, 8)), (
        f"Ranks must be contiguous 1..N, got {ranks}"
    )


def test_assign_rank_overall_inplace_false_copies(scoring):
    """
    v2.1.0: `assign_rank_overall(..., inplace=False)` must NOT mutate the
    input rows. v2.0.0 only tested the default inplace=True path.
    """
    rows = _make_rows(3)
    # Snapshot the rows BEFORE ranking
    snapshots = [dict(r) for r in rows]
    ranked = scoring.assign_rank_overall(rows, inplace=False)
    # Returned list should contain new dicts with rank_overall
    assert all("rank_overall" in r for r in ranked)
    # Original rows must not have rank_overall (weren't mutated)
    for original, snap in zip(rows, snapshots):
        assert "rank_overall" not in original or original.get("rank_overall") == snap.get(
            "rank_overall"
        ), (
            "inplace=False should not mutate input rows, but rank_overall appeared: "
            f"{original.get('rank_overall')}"
        )


