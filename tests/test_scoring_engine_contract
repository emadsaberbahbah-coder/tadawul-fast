#!/usr/bin/env python3
"""
tests/test_scoring_engine_contract.py
================================================================================
Scoring Engine Contract Tests — v2.0.0
================================================================================

What this test suite enforces
------------------------------
1) scoring module is importable from the expected paths
2) SCORING_VERSION is present and semver-shaped
3) compute_scores / score_row / enrich_with_scores are callable
4) AssetScores dataclass has all required fields
5) ScoreWeights dataclass has correct default weights
6) ForecastParameters dataclass is importable
7) ScoringEngine wrapper is callable (object-style API)
8) Recommendation vocabulary is canonical (STRONG_BUY/BUY/HOLD/REDUCE/SELL)
9) Risk bucket vocabulary is canonical (Low/Moderate/High)
10) Confidence bucket vocabulary is canonical (Low/Medium/High)
11) Score output fields are float in [0, 100] when present
12) Expected ROI fields are fractions when present (abs <= 1.5 for normal values)
13) Deterministic: same input → same output
14) Sparse row (minimal fields): does not raise, returns sensible defaults
15) Rich row (full instrument data): all score fields populated
16) rank_rows_by_overall / assign_rank_overall: correct ordering
17) score_and_rank_rows: end-to-end list scoring
18) enrich_with_scores: merges scores into the original row dict

Design goals
- No network calls.
- No FastAPI / async test infrastructure needed.
- Compatible with plain pytest.
- Import-safe: falls back gracefully when scoring module lives at different paths.
- Uses the v2.x project scoring.py API (compute_scores returns dict).
"""
from __future__ import annotations

