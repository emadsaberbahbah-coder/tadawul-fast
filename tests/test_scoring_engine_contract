def test_compute_scores_does_not_mutate_input(scoring):
    """
    v2.1.0: Defensive invariant — `compute_scores(row)` must not touch the
    caller's dict. It returns a patch dict; merging is the caller's job.
    """
    original = dict(RICH_ROW)
    snapshot_before = dict(original)
    _ = scoring.compute_scores(original)
    # Every key should still have the original value
    for k, v in snapshot_before.items():
        assert original.get(k) == v, (
            f"compute_scores mutated input: key '{k}' changed from {v!r} "
            f"to {original.get(k)!r}"
        )
    # No new keys should have been added either
    extra_keys = set(original.keys()) - set(snapshot_before.keys())
    assert not extra_keys, (
        f"compute_scores added keys to input dict: {extra_keys}"
    )


