!requirements-*.txt
!pyproject.toml
!poetry.lock
!pdm.lock
!uv.lock
!setup.py
!setup.cfg

# Deployment config (TFB canonical)
!render.yaml
!Procfile
!runtime.txt
!start_web.sh
!scripts/start_web.sh
!*.sh

# CI / GitHub Actions
!daily_sync*.yml
!.github/**/*.yml
!.github/**/*.yaml

# Project meta
!.gitignore
!.dockerignore
!.editorconfig
!README.md
!LICENSE
!LICENSE.md

# Templates and examples (explicit)
!docker-compose.example.yml
!config.example.yaml
!config.example.json
!.env.example
!.env.local.example


# =============================================================================
# FINAL SAFEGUARD
# =============================================================================
# This file is part of TADAWUL FAST BRIDGE v7.0.2
#
# DO NOT remove without understanding the security implications.
#
# Last-match-wins rule summary:
#  - A broader rule EARLIER can be overridden by a negation `!pattern` LATER.
#  - A negation on a parent directory does NOT re-include already-ignored
#    children (e.g., `!tests/` does NOT un-ignore `tests/.hypothesis/`).
#  - Root-anchored patterns start with `/` (e.g., `/tmp/` ignores only the
#    project-root tmp/, not `scripts/tmp/`).
# =============================================================================
