# =============================================================================
# DO NOT IGNORE SOURCE / CONFIG / PROJECT STRUCTURE
# =============================================================================
# This is an ALLOW-LIST: re-include files that would otherwise be matched
# by a broader ignore rule above. Gitignore rules are last-match-wins.
# These negations are placed LAST so they override everything above.

# Subdirectories
!core/
!routes/
!schemas/
!scripts/
!tests/
!integrations/
!docs/
!examples/
!migrations/
!notebooks/
!.github/

# Root-level app files
